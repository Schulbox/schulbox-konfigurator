{
  "version": 2,
  "functions": {
    "api/server.js": {
      "includeFiles": [
        "build/server/index.js",
        "build/client/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/server.js"
    }
  ]
}
