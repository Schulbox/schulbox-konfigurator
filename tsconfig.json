{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Node16",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "moduleResolution": "node16",
    "baseUrl": ".",                           // wichtig
    "paths": {
      "~/*": ["app/*"]                        // wichtig!
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "noEmit": true
  },
  "include": ["app", "env.d.ts"],
  "exclude": ["node_modules"]
}
